# ── GitHub App credentials ─────────────────────────────────────────────────────
# Find these in your GitHub App settings:
# https://github.com/settings/apps/your-app-name

# The numeric App ID shown on the App settings page
GITHUB_APP_ID=

# The webhook secret you set when creating the App
GITHUB_WEBHOOK_SECRET=

# The RSA private key downloaded from the App settings page.
# Paste the entire PEM file contents, replacing actual newlines with \n
# e.g. "-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----"
GITHUB_PRIVATE_KEY=

# ── Supabase ───────────────────────────────────────────────────────────────────
# Required for check run history (Phase 3 dashboard). Optional for local dev.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Required for paid tier billing (Phase 3). Optional for local dev.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
